# ==========================================================
# CORE - Git Ignore
# ==========================================================

# ----------------------------------------------------------
# R session files
# ----------------------------------------------------------

.Rhistory
.RData
.Ruserdata
.Rprofile

# ----------------------------------------------------------
# RStudio
# ----------------------------------------------------------

.Rproj.user/

# ----------------------------------------------------------
# Runtime logs
# ----------------------------------------------------------

logs/
*.log

# ----------------------------------------------------------
# Runtime outputs
# ----------------------------------------------------------

output/
outputs/
exports/
results/

# ----------------------------------------------------------
# Raw and processed research data
# ----------------------------------------------------------

data/raw/
data/processed/

# Keep only demo/example reference datasets
data/reference/*
!data/reference/.gitkeep
!data/reference/example*
!data/reference/test*

# ----------------------------------------------------------
# Temporary files
# ----------------------------------------------------------

*.tmp
*.temp

# ----------------------------------------------------------
# Package build artifacts
# ----------------------------------------------------------

*.tar.gz
*.Rcheck/

# ----------------------------------------------------------
# Quarto
# ----------------------------------------------------------

.quarto/
website/_site/
**/*.quarto_ipynb

# ----------------------------------------------------------
# Operating system files
# ----------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Environment files
# ----------------------------------------------------------

.Renviron
.env